  "keyFeatures": [
    "Nested goal hierarchies with unlimited depth",
    "Real-time collaboration with role-based permissions",
    "Shareable goal links for external viewing",
    "Goal templates for quick setup",
    "Progress tracking with manual and computed metrics",
    "Gamification with scoring and achievement ranks",
    "Recurring goals with daily/weekly cadence",
    "Comments and discussions on goals"
  ],
  "publicApiSurface": [
    "useGoals() - Fetch all top-level goals",
    "useGoal(id) - Fetch a single goal",
    "useSubGoals(parentId) - Fetch child goals",
    "useCreateGoal() - Create a new goal",
    "useUpdateGoal() - Update goal properties",
    "useDeleteGoal() - Delete a goal",
    "useCollaborators(goalId) - Fetch collaborators",
    "useAddCollaborator() - Add collaborator by email",
    "useUpdateCollaboratorRole() - Change collaborator role",
    "useRemoveCollaborator() - Remove a collaborator",
    "useShareLinks(goalId) - Fetch share links",
    "useCreateShareLink() - Create shareable link",
    "useRevokeShareLink() - Revoke a share link",
    "useGoalByToken(token) - Fetch goal via share token",
    "useComments(goalId) - Fetch goal comments",
    "useAddComment() - Add a comment",
    "useTemplates() - Fetch user templates",
    "useSaveTemplate() - Save goal as template",
    "useDeleteTemplate() - Delete a template",
    "useUserScore() - Fetch user score and rank"
  ]
}
